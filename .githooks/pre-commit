#!/bin/bash
# Exit on any error
set -e

echo "============================================="
echo "🔍 Running pre-commit quality checks..."
echo "============================================="

# Get list of staged files (files about to be committed)
CHANGED_FILES=$(git diff --cached --name-only)

# Filter only existing files (handles deleted files in diff)
EXISTING_FILES=""
for file in $CHANGED_FILES; do
  if [ -f "$file" ]; then
    EXISTING_FILES="$EXISTING_FILES $file"
  fi
done

CLIENT_CHANGED=false
SERVER_CHANGED=false

for file in $EXISTING_FILES; do
  if [[ $file == client/* ]]; then
    CLIENT_CHANGED=true
  fi
  if [[ $file == server/* ]]; then
    SERVER_CHANGED=true
  fi
done

# Run client checks if client files are staged
if [ "$CLIENT_CHANGED" = true ]; then
  echo "---------------------------------------------"
  echo "📦 Client changes staged. Checking types, tests, & linting..."
  echo "---------------------------------------------"
  cd client
  
  # Type check
  echo "Checking TypeScript types in client..."
  bun run check-types
  
  # Run client tests
  echo "Running client tests..."
  bun run test
  
  # Lint only staged client files
  CLIENT_FILES=$(echo "$EXISTING_FILES" | tr ' ' '\n' | grep '^client/' | sed 's/^client\///' | grep -E '\.(ts|tsx)$' | tr '\n' ' ' || true)
  if [ ! -z "$CLIENT_FILES" ]; then
    echo "Linting staged client files: $CLIENT_FILES"
    bun x eslint $CLIENT_FILES --fix --max-warnings 0
  else
    echo "No typescript files to lint in client."
  fi
  
  cd ..
fi

# Run server checks if server files are staged
if [ "$SERVER_CHANGED" = true ]; then
  echo "---------------------------------------------"
  echo "📦 Server changes staged. Checking build, tests, & linting..."
  echo "---------------------------------------------"
  cd server
  
  # Run server tests
  echo "Running server tests..."
  bun run test
  
  # Build/compilation check
  echo "Checking NestJS build in server..."
  bun run build
  
  # Lint only staged server files
  SERVER_FILES=$(echo "$EXISTING_FILES" | tr ' ' '\n' | grep '^server/' | sed 's/^server\///' | grep -E '\.(ts)$' | grep -v 'src/generated/' | grep -v 'src/custom/ogm/ogm-types.ts' | tr '\n' ' ' || true)
  if [ ! -z "$SERVER_FILES" ]; then
    echo "Linting staged server files: $SERVER_FILES"
    bun x eslint $SERVER_FILES --fix --max-warnings 0
  else
    echo "No typescript files to lint in server."
  fi
  
  cd ..
fi

echo "============================================="
echo "✅ All pre-commit checks passed successfully!"
echo "============================================="
exit 0
